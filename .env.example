# Database configuration
# For local development: sqlite:///humannetwork.db
# For production: mysql+pymysql://user:password@host/database
DATABASE_URL=sqlite:///humannetwork.db

# Flask secret key (REQUIRED - generate a secure one: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Optional: Google OAuth credentials (for OAuth login feature)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Email configuration for notifications
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
